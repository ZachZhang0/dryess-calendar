# .env 文件示例 - GitHub Actions
# 复制此文件为 .env 并填写实际值

# Supabase 基本配置
VITE_SUPABASE_URL=https://ehsfmciathifanermnoc.supabase.co
VITE_SUPABASE_ANON_KEY=你的 anon key

# GitHub Actions 使用的数据库连接字符串
# 格式：postgresql://postgres:密码@host:port/database
# 特殊字符需要 URL 编码：@→%40, :→%3A, /→%2F, #→%23
SUPABASE_DB_URL=postgresql://postgres:你的密码@db.ehsfmciathifanermnoc.supabase.co:5432/postgres
